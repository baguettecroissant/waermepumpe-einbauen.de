---
import { siteConfig } from '../../site.config';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: object[];
}

const {
  title,
  description = siteConfig.description,
  canonical,
  ogType = 'website',
  noindex = false,
  jsonLd = [],
} = Astro.props;

// Ensure trailing slash for canonical consistency with sitemap
const rawCanonical = canonical
  ? `https://${siteConfig.domain}${canonical}`
  : Astro.url.href;
const canonicalUrl = rawCanonical.endsWith('/') ? rawCanonical : rawCanonical + '/';
const ogImage = `https://${siteConfig.domain}/images/og-default.png`;
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteConfig.name} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon & App Icons (using 🔧 as dynamic vector favicon or simple emojis) -->
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🔧</text></svg>" />
  <meta name="theme-color" content="#004D40" />

  <!-- Preconnect & Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- JSON-LD Structured Data -->
  {jsonLd.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body class="min-h-screen flex flex-col bg-[#FAFAFA] text-[#212121]">
  <!-- Header Navbar -->
  <header id="main-nav" class="fixed top-0 left-0 right-0 z-50 navbar-scroll bg-transparent">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 group">
          <svg class="w-8 h-8 text-accent-500 group-hover:text-accent-400 transition-colors pulse-soft" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" fill="currentColor"/>
          </svg>
          <span class="font-bold text-lg text-white group-hover:text-brand-100 transition-colors font-heading">
            {siteConfig.domain}
          </span>
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-brand-50">
          <a href="/" class="hover:text-white transition-colors">Startseite</a>
          <a href="/ratgeber" class="hover:text-white transition-colors">Ratgeber</a>
          <a href="/impressum" class="hover:text-white transition-colors">Impressum</a>
          <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
          <a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/#devis-form" class="cta-gradient text-white px-5 py-2.5 rounded-lg font-semibold text-sm transition-all shadow-md hover:shadow-lg">
            🔧 Fachbetrieb finden →
          </a>
          <!-- Mobile hamburger -->
          <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-white/10 transition-colors" aria-label="Navigationsmenü">
            <span class="block w-5 h-0.5 bg-white rounded-full transition-transform" id="bar1"></span>
            <span class="block w-5 h-0.5 bg-white rounded-full transition-opacity" id="bar2"></span>
            <span class="block w-5 h-0.5 bg-white rounded-full transition-transform" id="bar3"></span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 z-50 hidden" aria-hidden="true">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="mobile-menu-backdrop"></div>
    <nav class="absolute top-0 right-0 w-72 h-full bg-brand-900 shadow-2xl flex flex-col overflow-y-auto transform translate-x-full transition-transform duration-300" id="mobile-menu-panel">
      <div class="flex items-center justify-between p-5 border-b border-brand-800">
        <span class="text-white font-bold font-heading text-lg">Menü</span>
        <button id="mobile-menu-close" class="text-white p-2 hover:bg-white/10 rounded-lg transition-colors" aria-label="Menü schließen">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div class="flex-1 p-5 space-y-1">
        <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-xl text-brand-50 hover:bg-white/10 transition-colors font-medium text-sm font-heading">🏠 Startseite</a>
        <a href="/ratgeber" class="flex items-center gap-3 px-4 py-3 rounded-xl text-brand-50 hover:bg-white/10 transition-colors font-medium text-sm font-heading">📚 Ratgeber</a>
        <a href="/kontakt" class="flex items-center gap-3 px-4 py-3 rounded-xl text-brand-50 hover:bg-white/10 transition-colors font-medium text-sm font-heading">✉️ Kontakt</a>
        <a href="/impressum" class="flex items-center gap-3 px-4 py-3 rounded-xl text-brand-50 hover:bg-white/10 transition-colors font-medium text-sm font-heading">⚖️ Impressum</a>
        <a href="/datenschutz" class="flex items-center gap-3 px-4 py-3 rounded-xl text-brand-50 hover:bg-white/10 transition-colors font-medium text-sm font-heading">🔒 Datenschutz</a>
      </div>
      <div class="p-5 border-t border-brand-800">
        <a href="/#devis-form" class="block w-full cta-gradient text-white text-center py-3.5 rounded-xl font-bold text-base shadow-lg transition-all" id="mobile-menu-cta">
          🔧 Fachbetrieb finden
        </a>
      </div>
    </nav>
  </div>

  <!-- Main content -->
  <main class="flex-1">
    <slot />
  </main>

  <!-- Footer -->
  <footer class="footer-bg py-12 mt-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 mb-8">
        <!-- Col 1: Über Uns -->
        <div class="col-span-2 md:col-span-1">
          <div class="flex items-center gap-2 mb-4">
            <svg class="w-6 h-6 text-accent-500" viewBox="0 0 24 24" fill="currentColor">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z" />
            </svg>
            <span class="text-white font-bold font-heading">{siteConfig.name}</span>
          </div>
          <p class="text-sm leading-relaxed text-gray-400 mb-4">{siteConfig.tagline}</p>
          <a href="/#devis-form" class="inline-block cta-gradient text-white text-xs font-bold px-4 py-2 rounded-lg shadow-sm hover:shadow-md transition-all">
            🔧 Fachbetrieb finden →
          </a>
        </div>

        <!-- Col 2: Ratgeber -->
        <div>
          <h4 class="text-white font-semibold mb-4 font-heading">📚 Ratgeber</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/ratgeber/waermepumpe-kosten-2026" class="hover:text-white transition-colors">Wärmepumpe Kosten</a></li>
            <li><a href="/ratgeber/waermepumpe-foerderung-2026" class="hover:text-white transition-colors">KfW-Förderung 2026</a></li>
            <li><a href="/ratgeber/luft-wasser-waermepumpe" class="hover:text-white transition-colors">Luft-Wasser-WP</a></li>
            <li><a href="/ratgeber/waermepumpe-altbau" class="hover:text-white transition-colors">WP im Altbau</a></li>
            <li><a href="/ratgeber/waermepumpe-vs-gasheizung" class="hover:text-white transition-colors">WP vs. Gasheizung</a></li>
            <li class="pt-1"><a href="/ratgeber" class="text-accent-500 hover:text-white transition-colors font-semibold">Alle Artikel →</a></li>
          </ul>
        </div>

        <!-- Col 3: Legal & Services -->
        <div>
          <h4 class="text-white font-semibold mb-4 font-heading">⚖️ Rechtliches</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/impressum" class="hover:text-white transition-colors">Impressum</a></li>
            <li><a href="/datenschutz" class="hover:text-white transition-colors">Datenschutzerklärung</a></li>
            <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
          </ul>
        </div>

        <!-- Col 4: Top-Städte -->
        <div class="col-span-2">
          <h4 class="text-white font-semibold mb-4 font-heading">📍 Regionaler Einbau</h4>
          <ul class="grid grid-cols-2 gap-2 text-sm text-gray-400">
            <li><a href="/waermepumpe-einbauen/berlin" class="hover:text-white transition-colors">Berlin</a></li>
            <li><a href="/waermepumpe-einbauen/hamburg" class="hover:text-white transition-colors">Hamburg</a></li>
            <li><a href="/waermepumpe-einbauen/munich" class="hover:text-white transition-colors">München</a></li>
            <li><a href="/waermepumpe-einbauen/cologne" class="hover:text-white transition-colors">Köln</a></li>
            <li><a href="/waermepumpe-einbauen/frankfurt-am-main" class="hover:text-white transition-colors">Frankfurt</a></li>
            <li><a href="/waermepumpe-einbauen/stuttgart" class="hover:text-white transition-colors">Stuttgart</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-800 pt-6 text-center text-xs text-gray-500">
        <p>© {new Date().getFullYear()} {siteConfig.name} — Alle Rechte vorbehalten. Die Angaben zur Installation dienen der Orientierung und sind unverbindlich.</p>
      </div>
    </div>
  </footer>

  <!-- Sticky Mobile CTA -->
  <div id="sticky-cta" class="fixed bottom-0 left-0 right-0 md:hidden z-40 bg-white border-t border-gray-200 p-3 shadow-xl sticky-cta-enter transition-transform duration-300" style="transform: translateY(100%);">
    <a href="#devis-form" class="block w-full cta-gradient text-white text-center py-3.5 rounded-xl font-bold text-base shadow-lg transition-all">
      🔧 Wärmepumpen-Fachbetriebe vergleichen
    </a>
  </div>

  <!-- DSGVO Cookie Banner -->
  <div id="cookie-consent-banner" class="fixed bottom-4 left-4 right-4 md:left-auto md:right-4 md:w-96 z-50 bg-white border border-gray-200 rounded-2xl p-5 shadow-2xl hidden transition-all duration-300">
    <div class="flex items-start gap-3">
      <span class="text-xl">🍪</span>
      <div>
        <h4 class="font-bold text-sm font-heading text-gray-900 mb-1">Cookie-Einstellungen</h4>
        <p class="text-xs text-gray-600 leading-relaxed mb-4">
          Wir nutzen Cookies, um unsere Website zu optimieren und unser Angebot für Sie stetig zu verbessern. Detaillierte Informationen finden Sie in unserer <a href="/datenschutz" class="text-brand-600 hover:underline">Datenschutzerklärung</a>.
        </p>
        <div class="flex items-center gap-2">
          <button id="cookie-accept" class="bg-brand-650 hover:bg-brand-700 text-white text-xs font-bold px-4 py-2 rounded-lg transition-colors cursor-pointer font-heading">
            Akzeptieren
          </button>
          <button id="cookie-decline" class="bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-bold px-4 py-2 rounded-lg transition-colors cursor-pointer font-heading">
            Ablehnen
          </button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
  (function() {
    // Navbar scroll effect
    var nav = document.getElementById('main-nav');
    if (nav) {
      window.addEventListener('scroll', function() {
        if (window.scrollY > 50) {
          nav.classList.add('navbar-scrolled');
        } else {
          nav.classList.remove('navbar-scrolled');
        }
      }, { passive: true });
    }

    // Mobile Menu
    var menuBtn = document.getElementById('mobile-menu-btn');
    var menuOverlay = document.getElementById('mobile-menu');
    var menuPanel = document.getElementById('mobile-menu-panel');
    var menuClose = document.getElementById('mobile-menu-close');
    var menuBackdrop = document.getElementById('mobile-menu-backdrop');
    var mobileCta = document.getElementById('mobile-menu-cta');

    function openMenu() {
      menuOverlay.classList.remove('hidden');
      menuOverlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(function() {
        menuPanel.classList.remove('translate-x-full');
      });
    }

    function closeMenu() {
      menuPanel.classList.add('translate-x-full');
      document.body.style.overflow = '';
      setTimeout(function() {
        menuOverlay.classList.add('hidden');
        menuOverlay.setAttribute('aria-hidden', 'true');
      }, 300);
    }

    if (menuBtn) menuBtn.addEventListener('click', openMenu);
    if (menuClose) menuClose.addEventListener('click', closeMenu);
    if (menuBackdrop) menuBackdrop.addEventListener('click', closeMenu);
    if (mobileCta) mobileCta.addEventListener('click', closeMenu);

    // Sticky CTA
    var cta = document.getElementById('sticky-cta');
    if (cta) {
      var formVisible = false;
      var scrolledPastHero = false;
      var formEl = document.getElementById('devis-form');

      function updateCTA() {
        if (formVisible || !scrolledPastHero) {
          cta.style.transform = 'translateY(100%)';
        } else {
          cta.style.transform = 'translateY(0)';
        }
      }

      window.addEventListener('scroll', function() {
        scrolledPastHero = window.scrollY > 300;
        updateCTA();
      }, { passive: true });

      if (formEl && 'IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          formVisible = entries[0].isIntersecting;
          updateCTA();
        }, { threshold: 0.3 });
        observer.observe(formEl);
      }

      cta.querySelector('a').addEventListener('click', function(e) {
        if (formEl) {
          e.preventDefault();
          formEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    }

    // DSGVO Cookie Banner Logic
    var banner = document.getElementById('cookie-consent-banner');
    var acceptBtn = document.getElementById('cookie-accept');
    var declineBtn = document.getElementById('cookie-decline');

    if (banner && acceptBtn && declineBtn) {
      var consent = localStorage.getItem('cookie-consent');
      if (!consent) {
        setTimeout(function() {
          banner.classList.remove('hidden');
        }, 1500);
      }

      acceptBtn.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'accepted');
        banner.classList.add('hidden');
      });

      declineBtn.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'declined');
        banner.classList.add('hidden');
      });
    }
  })();
  </script>
</body>
</html>
